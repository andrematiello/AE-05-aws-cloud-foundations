# Copy to terraform.tfvars and fill in real values. Never commit terraform.tfvars itself
# (already in .gitignore) — bucket names are not secret, but keeping the pattern consistent
# with how credentials are handled elsewhere in this portfolio avoids mistakes.

aws_region        = "us-east-1"
docs_bucket_name  = "ae05-dbt-docs-CHANGE-ME"
data_bucket_name  = "ae05-market-data-CHANGE-ME"
key_pair_name     = "CHANGE-ME"
ssh_allowed_cidr  = "CHANGE-ME/32"
budget_alert_email = "CHANGE-ME@example.com"
